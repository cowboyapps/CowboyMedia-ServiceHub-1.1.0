# ServiceHub environment configuration
# Copy to /opt/servicehub/.env and fill in real values.
# Lines marked [REQUIRED] must be set or the app will not function.

# ---- Core ---------------------------------------------------------------
# [REQUIRED] Postgres connection string (local socket or TCP)
DATABASE_URL=postgres://servicehub:CHANGEME@127.0.0.1:5432/servicehub

# [REQUIRED] Random 64+ char hex string. NEVER regenerate on a live install
# (doing so logs every user out). Generate fresh with: openssl rand -hex 48
SESSION_SECRET=

# [REQUIRED] Public-facing base URL of the app, no trailing slash.
# Used to build links in outbound emails (password reset, etc).
# In production this MUST be set — password-reset emails refuse to send
# without it (so an attacker cannot inject a phishing link via Host header).
APP_BASE_URL=https://status.example.com

# Optional: opt in to deriving the password-reset link base URL from the
# request Host header when APP_BASE_URL and REPLIT_DOMAINS are both unset.
# Default off because Host is attacker-controllable. Only enable behind a
# strict reverse proxy that rewrites Host.
# ALLOW_HOST_HEADER_BASE_URL=false

# Node env. Always "production" on the VPS.
NODE_ENV=production

# Listen port. Nginx proxies to this. Default 5000.
PORT=5000

# ---- Web Push (VAPID) ---------------------------------------------------
# [REQUIRED for push] Generate ONCE with: npx web-push generate-vapid-keys
# NEVER regenerate on a live install — all existing browser subscriptions
# become permanently dead.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for VAPID identity. Email or https URL. Browsers may use it on abuse.
VAPID_CONTACT_EMAIL=admin@example.com

# ---- Email (SendGrid) ---------------------------------------------------
# [REQUIRED for outbound email] SendGrid API key.
SENDGRID_API_KEY=

# ---- Telegram (optional) ------------------------------------------------
# Bot token for the Telegram group notifications feature.
# Chat ID + enable toggle live in the DB (telegram_settings), not here.
TELEGRAM_BOT_TOKEN=

# ---- OneSignal (optional, legacy) ---------------------------------------
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ---- Firebase (optional, legacy) ----------------------------------------
# Single-line JSON of the service account credentials.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---- Backups (used by deploy/backup.sh, not by the app) -----------------
# Passphrase used to encrypt nightly DB dumps before upload.
BACKUP_ENCRYPTION_PASSPHRASE=
# rclone remote name (configured separately with `rclone config`).
BACKUP_RCLONE_REMOTE=b2:servicehub-backups
